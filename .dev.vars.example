# ローカル開発用の環境変数
# このファイルを .dev.vars にコピーして実際の値を設定してください
# .dev.vars は .gitignore に追加済みです（コミットしないでください）

# Cloudflare Account ID
# https://dash.cloudflare.com/ の右サイドバーで確認
CLOUDFLARE_ACCOUNT_ID=your_account_id_here

# Cloudflare API Token
# https://dash.cloudflare.com/profile/api-tokens で生成
# 必要な権限: Workers AI (Read), Workers Scripts (Edit)
CLOUDFLARE_API_TOKEN=your_api_token_here

# ベアラートークン認証（デフォルト: 無効）
# 設定した場合、/mcp と /api/* へのすべてのリクエストに
# Authorization: Bearer <token> ヘッダーが必要になります。
# 未設定の場合は認証なし（後方互換）。
# API_SECRET=your_secret_token_here

# 画像変換の有効化（デフォルト: 無効）
# 画像変換（JPEG/PNG/WebP/SVG）は Workers AI モデルを使用するため費用が発生する可能性があります。
# 有効化する場合は "true" を設定してください。
# ENABLE_IMAGE_CONVERSION=true
